# Xiaozhi MCP Bridge Configuration
# Copy this file to .env and fill in your values

# Required: xiaozhi.me MCP endpoint (get from xiaozhi.me dashboard -> MCP Access Point)
# Format: wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE
MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=

# Optional: Your MCP server URL (default provided)
# This is your HTTP MCP server that will provide the tools
MCP_URL=https://xiaozhi-mcp-server.skr4test.workers.dev/mcp

# Optional: Server port (default: 10000)
PORT=10000